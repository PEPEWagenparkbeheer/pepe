# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq (LLM extract voor leads + facturen)
GROQ_API_KEY=

# Anthropic (Claude – voor BREIN en tenders)
ANTHROPIC_API_KEY=

# Postmark inbound webhooks (auth via ?secret=)
LEADS_WEBHOOK_SECRET=
FACTUREN_WEBHOOK_SECRET=

# HubSpot (Private App token)
HUBSPOT_TOKEN=

# ── BREIN ──────────────────────────────────────────────────────────────
# Microsoft Azure App Registration (client credentials / app-only)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Mailbox die BREIN in de gaten houdt
BREIN_MAILBOX=fues@pepewagenparkbeheer.nl

# Webhook secret voor /api/brein/sync (zelfde patroon als andere inbound-routes)
BREIN_SYNC_SECRET=

# DocuSign (JWT / service account) — zelfde var-namen als de wpb-klantportal
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
# Private key als base64 (single-line): base64 van het complete .pem-bestand.
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("private.pem"))
DOCUSIGN_PRIVATE_KEY_B64=
# Endpoints: demo (sandbox) of productie
DOCUSIGN_OAUTH_BASE=account-d.docusign.com
DOCUSIGN_BASE_URI=https://demo.docusign.net/restapi

# ── Tender-automatisering · Skyvern Cloud ──────────────────────────────
# API-key uit app.skyvern.com → Settings → API Keys (betaald: credits per stap)
SKYVERN_API_KEY=
# Max stappen per portaal-run (kostenrem; default 40). Lager = goedkoper/veiliger.
SKYVERN_MAX_STEPS=40
# Timeout per run in SECONDEN (default 600 = 10 min)
SKYVERN_TIMEOUT_SEC=600
